# ChatFlow Vercel 生产环境导入模板
# 用法：
# 1. 先在 Vercel 里接入 Supabase for Vercel（或其他 Postgres 集成）
# 2. 再把本文件复制一份，替换下面的占位符
# 3. 在 Vercel -> Settings -> Environment Variables 里导入

# Database
# 如果你使用 Supabase for Vercel，这两个变量通常会由集成自动注入。
# 不建议先导入空值，否则可能覆盖掉后续自动注入的正确值。
# POSTGRES_PRISMA_URL="postgres://YOUR_POOLING_DATABASE_URL"
# POSTGRES_URL_NON_POOLING="postgres://YOUR_DIRECT_DATABASE_URL"

# NextAuth.js
NEXTAUTH_URL="https://YOUR_PROJECT_NAME.vercel.app"
NEXTAUTH_SECRET="REPLACE_WITH_BASE64_SECRET"

# OAuth Providers
GOOGLE_CLIENT_ID="REPLACE_WITH_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="REPLACE_WITH_GOOGLE_CLIENT_SECRET"
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Encryption
ENCRYPTION_KEY="REPLACE_WITH_64_HEX_ENCRYPTION_KEY"
